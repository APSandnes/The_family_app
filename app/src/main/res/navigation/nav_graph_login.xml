<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_login"
    app:startDestination="@id/loginFragment">
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.mainactivity.fragment.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/action_loginFragment_to_signupFragment"
            app:destination="@id/signupFragment" />
        <action
            android:id="@+id/action_loginFragment_to_familieFragment"
            app:destination="@id/familieFragment" />
    </fragment>
    <fragment
        android:id="@+id/signupFragment"
        android:name="com.example.mainactivity.fragment.SignupFragment"
        android:label="fragment_signup"
        tools:layout="@layout/fragment_signup" >
        <action
            android:id="@+id/action_signupFragment_to_familieFragment"
            app:destination="@id/familieFragment" />
    </fragment>
    <fragment
        android:id="@+id/familieFragment"
        android:name="com.example.mainactivity.fragment.FamilyFragment"
        android:label="fragment_family"
        tools:layout="@layout/fragment_family" >
        <action
            android:id="@+id/action_familieFragment_to_familieBliMedlemFragment"
            app:destination="@id/familieBliMedlemFragment" />
        <action
            android:id="@+id/action_familieFragment_to_familieCreateFragment"
            app:destination="@id/familieCreateFragment" />
    </fragment>
    <fragment
        android:id="@+id/familieBliMedlemFragment"
        android:name="com.example.mainactivity.fragment.FamilyJoinFragment"
        android:label="fragment_family_join"
        tools:layout="@layout/fragment_family_join" />
    <fragment
        android:id="@+id/familieCreateFragment"
        android:name="com.example.mainactivity.fragment.FamilyCreateFragment"
        android:label="fragment_family_create"
        tools:layout="@layout/fragment_family_create" />
</navigation>